Console.WriteLine("Welcome to the Guessing game of Consolas to determine the enemy's location");
int userNumber = -1;
while (userNumber < 0 || userNumber > 100)
{
    Console.WriteLine("User 1, Enter a number between 0 and 100: ");
    string userResponse = Console.ReadLine();
    userNumber = Convert.ToInt32(userResponse);
}

Console.Clear();

Console.WriteLine("User 2, guess the number");

while (true)
{
    Console.Write("What is your next guess? ");
    string input = Console.ReadLine();
    int number = Convert.ToInt32(input);
    if (number == userNumber)
    {
        Console.WriteLine("You guessed the number!");
        break;
    }
    else if (number > userNumber)
        Console.WriteLine($"{number} is too high.");
    else
        Console.WriteLine($"{number} is too low.");
}
Console.ReadKey();
